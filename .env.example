# HTTP
PORT=3000
NODE_ENV=development

# CORS: comma-separated extra browser origins (never use *).
# http://localhost:5173 and http://127.0.0.1:5173 (Vite) are always allowed in addition to this list.
# In production, set your deployed SPA origin(s), e.g. https://learnstockmarket.online
STOCKS_SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Behind nginx/Cloudflare/etc. set true so rate limits use the real client IP
# TRUST_PROXY=true

# Market data API auth (existing) — see README
# STOCKS_SERVER_API_KEY=
# STOCKS_SERVER_API_CLIENTS=
# STOCKS_SERVER_JWT_SECRET=

# Alpaca / Finnhub / Alpha Vantage / FRED — same as before

# App API (auth, profile, Stripe billing, social shares) — same Supabase project as the web app
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Billing routes (/billing/*)
STRIPE_SECRET_KEY=
