# HTTP
PORT=3000
NODE_ENV=development

# CORS: comma-separated browser origins for the SPA (where users open the site), never *.
# http://localhost:5173 and http://127.0.0.1:5173 (Vite) are always merged in addition to this list.
# Production: include https://learnstockmarket.online and https://www.learnstockmarket.online (Netlify).
# Do NOT list your API hostname (e.g. api.learnstockmarket.online) — CORS Origin is the page URL, not the API.
STOCKS_SERVER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set true on Render, nginx, Cloudflare, etc. so rate limits see the real client IP.
# TRUST_PROXY=true

# Market data API auth (existing) — see README
# STOCKS_SERVER_API_KEY=
# STOCKS_SERVER_API_CLIENTS=
# STOCKS_SERVER_JWT_SECRET=
#
# Browser SPAs should send `Authorization: Bearer <Supabase access_token>` for /v1/*; tier is resolved from user_subscriptions.
# Logged-out users hit /v1 without credentials as anonymous visitors (free + visitor entitlements) unless you set:
# STOCKS_SERVER_V1_ANONYMOUS_VISITOR=false

# Alpaca / Finnhub / Alpha Vantage / FRED — same as before

# App API (auth, profile, Stripe billing, social shares) — same Supabase project as the web app
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Billing routes (/billing/*) — server only. Must be the Secret key (sk_test_... / sk_live_...).
# Do NOT put the publishable key (pk_...) here — that causes "cannot be made with a publishable API key".
# In the Vite SPA repo, set VITE_STRIPE_PUBLIC_KEY=pk_... for Elements / client-side Stripe.js.
# PaymentIntent amounts (cents) and tiers must match the web app `src/lib/tiers.ts`.
STRIPE_SECRET_KEY=
